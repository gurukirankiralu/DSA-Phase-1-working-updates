    //1)sum of n natural numbers.

    static int sumOfNumbers(int n){
        int sum=0;
        for(int i=1;i<=n;i++){
            sum+=i;
        }
        return sum;//return (n*n+1)/2;

    }

    //2)compute 1/n!.
    static double oneByFact(int n){
        return (double) 1/factorial(n);
    }
    //power
    static int power(int base,int expo){
        int pow=1;
        while(expo>0){
            pow*=base;
            expo--;
        }
        return pow;
    }
    //3) compute x^n/n!.
    static int  poereByFactorial(int x,int n){
        return power(x,n/factorial(n));
    }
    //4)count the number of digits in an integer.
    static int count(int n){
        if(n<0){
            n*=-1;
        }
        if(n<10){
            return 1;
        }
        int count=0;
        while(n>0){
            count++;
            n/=10;
        }
        return count;
    }
    //5)sum all digits of a number.
    static int sumOfAllDigit(int num){
        if(num<0){
            num*=-1;
        }
        if(num<10){
            return num;
        }
        int sum=0;
        while (num>0){
            sum+=num%10;
            num/=10;
        }
        return sum;

    }
    // 6)reverse a given number.
    static int reverse(int num){
        int rev=0;
        while(num>0){
            rev=rev*10+num%10;
            num/=10;
        }
        return rev;
    }
    //G.C.D or HCF of two numbers.
    static int larger(int a,int b){
        if(a>b){
            return a;
        }
        return b;
    }
    // 7)G.C.D or HCF of two numbers.
    static int GCD(int a,int b){
        while(b!=0){
            int rem=a%b;
            a=b;
            b=rem;
        }
        return a;
    }
    //8) LCM of two numbers
    static int LCM(int a,int b){
        return (a*b)/GCD(a,b);
    }
    //9) factorial
    static int factorial(int n){
        int fact=1;
        while(n>0){
            fact*=n;
            n-=1;
        }
        return fact;
    }
    // 10)prime Factors of number
    static void primeFactor(int num){
        int prime=2;
        while(num>1){
            if(num%prime==0){
                System.out.print(prime);
                num/=prime;
            }
            else {
                prime++;
            }
            if(prime*prime>num&&num>1){
                System.out.println(num);
                break;
            }
        }
    }
    //a palindrome or not.
    static boolean isPalindrome (int num){
        return num==reverse(num);
    }
    //12)number is prime or not.
    static boolean isprime(int num){
        if(num==0||num==1){
            return false;
        }
        for(int i=2;i<= Math.sqrt(num);i++){
            if(num%i==0){
                return false;
            }
        }
        return true;
    }
    // 13)a perfect square
    static boolean isPerfectSquare(int num){
        for(int i=1;i*i<=num;i++){
            if(i*i==num){
                return true;
            }
        }
        return false;
    }
    // 14)Armstrong
    static boolean armstrong(int num){
        int count=count(num);
        int original=num;
        int arm=0;
        while (num>0){
            int last=num%10;
            arm=arm+power(last,count);
            num/=10;
        }
        if(arm==original){
            return true;
        }
        return false;
    }
    // 15)strong number
    static  boolean strongNumber(int num){
        int sum=0;
        int original=num;
        while(num>0){
            sum+=factorial(num%10);
            num/=10;
        }
        if(sum==original){
            return true;
        }
        return false;
    }

// 16)perfect number
    static boolean perfectNumber(int num){
        if(num<=0){
            return false;
        }
        int sum=0;
        for(int i=1;i<num;i++){
            if(num%i==0){
                sum+=i;
            }
        }
        if(sum==num){
            return true;
        }
        return false;
    }
    //17)Harshad number
    static boolean harshand(int num){
        if(num<0){
            num*=-1;
        }
        if(num<10){
            return true;
        }
        int sum=0;
        int temp=num;
        while(temp>0){
            sum+=temp%10;
            temp/=10;
        }
        if(num%sum==0){
            return true;
        }
        return false;
    }
    //18) Abundant number
    static boolean abundant(int num){
        if(num<0){
            num*=-1;
        }
        int sum=0;
        for(int i=1;i<=num/2;i++){
            if(num%i==0){
                sum+=i;
            }
        }
        if(sum>num){
            return true;
        }
        return false;
    }
    //19) Automorphic
    static  boolean automorphic(int num){
        if(num<0){
            num*=-1;
        }
        int digit=count(num);
        if(num==(num*num)%power(10,digit)){
            return true;
        }
        return false;
    }
    //20)Magic Number
    static boolean magic(int num){
        if(num<0){
            num*=-1;
        }
        if(num==0){
            return false;
        }
        while(num>9){
            num=sumOfAllDigit(num);
        }
        return num==1;
    }
    static int sumOfDiviser(int num){
        if(num<0){
            num*=-1;
        }
        int sum=0;
        for(int i=1;i<=num;i++){
            if(num%i==0){
                sum+=i;
            }
        }
        return sum;
    }
    //21)Friendly pair
    static boolean friendly(int a,int b){
        return (sumOfDiviser(a)*b==sumOfDiviser(b)*a);
    }
    // 22)Neon Number
    static boolean neonNumber(int num){
        int squar=num*num;
        return num==sumOfAllDigit(squar);
    }
    static int productOfDigits(int num){
        int product=1;
        while(num>0){
            product*=num%10;
            num/=10;
        }
        return product;
    }
    //23) Spy Number
    static boolean spyNumber(int num){
        return sumOfAllDigit(num)==productOfDigits(num);
    }
    static int sumOfSquareDigit(int num){
        int sum=0;
        while(num>0){
            int digit=num%10;
            sum+=digit*digit;
            num/=10;
        }
        return sum;
    }
    // 24)Happy Number
    static boolean happy(int num){
        int original=num;
        while (num!=1){
            num=sumOfSquareDigit(num);
