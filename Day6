    int powerWithNext(int num){
        int result=0;
        int first=num/power(10,count(num)-1);
        int last=num%10;
        while (num>9){
            result=result+power(first(num),second(num));
            //System.out.println(result);
            num=num%power(10,count(num)-1);
        }
        result+=power(last,first);
        return result;
    }
