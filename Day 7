    static int countEven(int num){
        int count =0;
        while (num>0){
            int digit =num%10;
            while (digit==0){
                num/=10;
                digit=num%10;
            }
            if(digit%2==0){
                count++;
            }
            num/=10;
        }
        return count;
    }
    static int nDigitHappyEven(int n){
        for(int i=power(10,n-1);i<power(10,n);i++) {
            if (happy(i)) {
                if (countEven(i) >= 2) {
                    return i;
                }
            }
        }
        return -1;
    }


    //49 nth prime number
    static int nthPrime(int n){
        int c=0;
        for(int i=2;c<n;i++){
            if(isprime(i)){
                c++;
            }
            if(c==n){
                return i;
            }
        }
        return -1;
    }
    static int squreroot(int num){
        int prev=0;
        for( int i=1;i*i<=num;i++){
             if(i*i==num){
                 return i;
             }
             prev=i;
        }
        return  prev;
    }
    static  boolean prime2(long num){
        if(num<2){
            return false;
        }
        if(num%2==0||num%3==0){
            return false;
        }
        for(long i=5;(i*i)<=num;i+=6){
            if(num%i==0||num%i+2==0){
                return false;
            }
        }
        return true;
    }
    static long power2(int base,int expo){
        long pow=1;
        while(expo>0){
            pow*=base;
            expo--;
        }
        return pow;
    }

    static long  nDigitNthPrime(int n) {
        int c=1;
        for (long i = power2(10, n - 1); i < power2(10, n); i++) {
            if(prime2(i)){
                c++;
            }
            if(c==n){
                return i;
            }
        }
        return -1;
    }

