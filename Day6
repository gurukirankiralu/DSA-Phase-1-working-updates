    public int reverseCouple(int num){
        int last=0;
        boolean isOdd=false;
        if(count(num)%2!=0){
            isOdd=true;
            last=num%10;
            num/=10;
        }
        int result=0;
        while(num!=0){
            int count=count(num);
            int digit=num/power(10,count-2);
            result=result*10+digit%10;
            digit=digit/10;
            result=result*10+digit%10;
            num=num%power(10,count-2);
        }
        if(isOdd){
            result=result*10+last;
        }
        return result;
    }
