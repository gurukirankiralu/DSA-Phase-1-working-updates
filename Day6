    public int concatFirstLast(int num,int n){
        int countNum=count(num);
        int countN=count(n);
        int first =(int)(n*Math.pow(10,countNum)+num);
        return (int)(first*Math.pow(10,countN)+n);

    }
    public int concatMiddele(int num,int n){
        boolean isNegitive=false;
        if(num<0){
            isNegitive=true;
            num*=-1;
        }
        int cnum=count(num);
        int half=cnum/2;
        int cn=count(n);
        int first=num/power(10,cnum-half);
        int last=num%power(10,cnum-half);
        int lc=count(last);
        if(isNegitive){
            return ((first*power(10,cn)+n)*power(10,lc)+last)*-1;
        }
        return (first*power(10,cn)+n)*power(10,lc)+last;
    }
    void creatEvenOdd(int num){
        int even=0;
        int odd=0;
        while(num!=0){
            int count=count(num);
            int digit=num/power(10,count-1);
            if(digit%2==0){
                even=even*10+digit;
                num=num%power(10,count-1);
            }
            else{
                odd=odd*10+digit;
                num=num%power(10,count-1);
            }
        }
        System.out.println("even :"+even);
        System.out.println("odd :"+odd);

    }
    long addAlternative(int num,int n){
        int countN=count(n);
        long result=0;
        while(num!=0){
            int countNum=count(num);
            int digit=num/power(10,countNum-1);
            result=((result*10+digit)*power(10,countN))+n;
          //  System.out.println(result);
            num=num%power(10,countNum-1);
        }
        return result;
    }
    public int sumOfNumber(int num){
        int totalSum=0;
        while(num>0){
            int digit=num%10;
            int sum=0;
            for(int i=1;i<=digit;i++){
                sum+=i;
            }
            totalSum+=sum;
            num/=10;
        }
        return totalSum;
    }
