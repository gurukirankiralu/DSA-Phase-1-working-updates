        }
        return true;

    }
    //25)Sunny Number
    static boolean sunny(int num){
        return isPerfectSquare(num+1);
    }
    //26)Disarium Number
    static boolean disariumNumber(int num){
        if(num<0){
            num*=-1;
        }
        if(num==0){
            return false;
        }
        if(num<10){
            return true;
        }
        int original=num;
        int count =count(num);
        int disaium=0;
        while (count>0){
            int digit=num%10;
            disaium+=power(digit,count);
            count--;
            num/=10;
        }
        return disaium==original;
    }
    //27 Pronic Number
    static boolean pronic(int num){
        for(int i=1;i<Math.sqrt(num);i++){
            if(i*i+i==num){
                return true;
            }
        }
        return false;
    }
    static int cube(int num){
        return num*num*num;
    }
    //28)Trimorphic Number
    static boolean trimorphic(int num){
        int digit=count(num);
        return cube(num)%power(10,digit)==num;
    }
    // 29)Evil Number
    static boolean evilNumber(int num){
        int count=0;
        while(num>0){
            int rem=num%2;
            if(rem==1){
                count++;
            }
            num/=2;
        }
        return count%2==0;
    }
