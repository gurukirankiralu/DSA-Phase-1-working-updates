    // 48)Find the nth palindrome number.
    static int nthPalindrome(int n){
        int count =0;
        int i=1;
        while (true){
            if(isPalindrome(i)){
                count++;
            }
            if(count==n){
                return i;
            }
            i++;
        }
    }
